@startuml architecture-minimal

!theme plain
skinparam backgroundColor white
skinparam componentStyle rectangle
skinparam defaultFontName monospaced
skinparam nodesep 50
skinparam ranksep 40
skinparam padding 6

title Minimal Architecture with Read/Write

actor "Application" as app1

node "Docker Host" as host1 {
    component "pgauthzd\n:8080" as pgd1 #LightGreen
    database "PostgreSQL\n:5432" as pg1 #Orange
}

' Minimal = no OPA: pgauthzd is the front door, answering straight from the
' ReBAC graph (decision-only for reads, full for writes). Add OPA only when you
' need Rego policy enrichment (see the full / enterprise diagrams).
app1 -down-> pgd1 : "AuthZEN / native API\n(authz checks + tuple writes)"
pgd1 -down-> pg1 : "SQL (pgx)"

legend bottom left
  |= Color |= Component |
  | <#LightGreen> | pgauthzd — the front door (AuthZEN + native API) |
  | <#Orange> | PostgreSQL — single instance |
end legend

@enduml
