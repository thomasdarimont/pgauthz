@startuml architecture-token-flow

!theme plain
skinparam backgroundColor white
skinparam defaultFontName monospaced
skinparam sequenceMessageAlign left
skinparam maxMessageSize 260

title Where tokens are validated — pgauthzd is the front door

actor "Client" as app
participant "pgauthzd\n(front door)" as pgd
participant "OPA\n(sidecar)" as opa
database "PostgreSQL\nengine (SECURITY DEFINER)" as pg

group Direct read (decision-only) — no OPA
  app -> pgd : POST /access/v1/evaluation\nAuthorization: Bearer <jwt>
  note right of pgd
    **pgauthzd validates the JWT** —
    multi-issuer (JWT_ISSUERS, the
    "iss" claim selects the validator);
    subject & roles from claims.
    Then answers straight from the graph.
  end note
  pgd -> pg : check_access(...) via pgx
end

group Policy read (OPA_URL set) — pgauthzd consults OPA
  app -> pgd : POST /access/v1/evaluation\nAuthorization: Bearer <jwt>
  note right of pgd
    pgauthzd validates the JWT, then
    forwards it to its OPA sidecar
    (FORWARD_TOKEN_TO_OPA) — defense in depth.
  end note
  pgd -> opa : consult policy\n(input.token = <jwt>)
  note right of opa
    **OPA re-validates** the token and
    evaluates Rego; for graph data it
    calls BACK into pgauthzd's native
    listener (service token) — the only
    caller of OPA is pgauthzd.
  end note
  opa -> pgd : native /pgauthz/v1/check
  pgd -> pg : check_access(...) via pgx
  opa --> pgd : decision
end

group Write — pgauthzd fronts and authorizes
  app -> pgd : POST /pgauthz/v1/write\n{ tuple }  Authorization: Bearer <jwt>
  note right of pgd
    **pgauthzd validates the JWT and
    requires the writer role itself**
    (WRITER_ROLE in JWT_ROLES_CLAIM) —
    no OPA on the write path.
    Then applies the write natively.
  end note
  pgd -> pg : write_tuples_jsonb(...) via pgx
end

@enduml
