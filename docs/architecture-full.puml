@startuml architecture-full

!theme plain
skinparam backgroundColor white
skinparam componentStyle rectangle
skinparam defaultFontName monospaced
skinparam nodesep 50
skinparam ranksep 40
skinparam padding 6

title Full Architecture (read scaling + write API + AuthZEN)

actor "Application" as app

component "Load Balancer" as lb #Plum

node "VM 1 (read)" as vm1 {
    component "OPA" as opa_a #LightBlue
    component "AuthZEN" as az_a #PaleGreen
    component "pgauthzd\n(reader)" as pgd_a #LightGreen
    database "PG Replica" as pgr_a #LightYellow
}

node "VM 2 (read)" as vm2 {
    component "OPA" as opa_b #LightBlue
    component "AuthZEN" as az_b #PaleGreen
    component "pgauthzd\n(reader)" as pgd_b #LightGreen
    database "PG Replica" as pgr_b #LightYellow
}

node "VM 0 (primary)" as vm0 {
    component "OPA\n(write front)" as opa_w #LightBlue
    component "pgauthzd\n(writer)" as pgd_w #Salmon
    database "PG Primary" as pgp #Orange
}

' Read path
app -down-> lb : "authz checks\n(read path)"
lb -down-> opa_a : "OPA data API\n/v1/data/authz/*"
lb -down-> opa_b
lb -down-> az_a : "AuthZEN 1.0 API\n/access/v1/*"
lb -down-> az_b
opa_a -down-> pgd_a : "native callback"
opa_b -down-> pgd_b
az_a -down-> opa_a : "compat-opa\n(policy-enriched)"
az_a -down-> pgr_a : "decision-only\n(SQL, lowest latency)"
az_b -down-> opa_b
az_b -down-> pgr_b
pgd_a -down-> pgr_a
pgd_b -down-> pgr_b

' Write path — OPA fronts the writer (verifies JWT + writer role, forwards)
app -down-> opa_w : "writes\n(JWT: writer role)"
opa_w -down-> pgd_w : "native write callback\n(authorized)"
pgd_w -down-> pgp : "SQL (pgx, authz_writer)"

' Replication
pgp -right-> pgr_a : "  WAL  "
pgp -right-> pgr_b : "  WAL  "

legend bottom left
  |= Color |= Component |
  | <#PaleGreen> | AuthZEN API — AuthZEN 1.0 (pgauthzd); decision-only → PG, compat-opa → OPA |
  | <#LightBlue> | OPA — policy evaluation + JWT authn (reads and writes) |
  | <#LightGreen> | pgauthzd (reader) — decision-only; OPA read callback (native) |
  | <#Salmon> | pgauthzd (writer) — full profile; OPA write callback (authz_writer) |
  | <#Orange> | PostgreSQL primary — read-write |
  | <#LightYellow> | PostgreSQL replica — read-only (WAL) |
  | <#Plum> | Load Balancer — distributes reads |
end legend

@enduml
