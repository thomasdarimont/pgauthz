@startuml architecture-write-api

!theme plain
skinparam backgroundColor white
skinparam componentStyle rectangle
skinparam defaultFontName monospaced
skinparam nodesep 50
skinparam ranksep 40
skinparam padding 6

title Architecture with Write Paths

actor "Application" as app

note as N1
  **Option A: Write API (OPA-fronted)**
  For applications without direct
  database access. OPA verifies the
  JWT and the writer role, then
  forwards the write to the fixed-role
  writer (which does no JWT of its own).
end note

node "HTTP Write API" as optA {
    component "OPA\n:8181" as opa #LightBlue
    component "PostgREST Writer\n(internal, authz_writer)" as pgrst #Salmon
}

database "PostgreSQL\n:5432" as pg #Orange

N1 -right-> opa

app -down-> opa : "POST /v1/data/authz/write\n(JWT: writer role)"
opa -down-> pgrst : "forward write/delete\n(authorized only)"
pgrst -down-> pg : "SQL (authz_writer)"

app -right-> pg : "direct SQL\n(authz_writer role)"

note right of pg
  **Option B: Direct SQL**
  For applications with
  direct PostgreSQL connectivity
  (lowest latency, no HTTP overhead)
end note

legend bottom left
  |= Color |= Component |
  | <#LightBlue> | OPA — verifies JWT + writer role, forwards the write |
  | <#Salmon> | PostgREST Writer — fixed authz_writer role, no JWT |
  | <#Orange> | PostgreSQL — authz schema |
end legend

@enduml
