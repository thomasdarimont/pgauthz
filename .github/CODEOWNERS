# Review gates for security-sensitive paths. With branch protection
# requiring code-owner reviews, changes here need the owner's approval.
# (Single-maintainer today; the value is the explicit inventory of what
# counts as security-critical, and the gate activates as the team grows.)

# The authorization engine's privileged surface
/db/security/       @thomasdarimont
/db/migrations/     @thomasdarimont
/db/engine/         @thomasdarimont

# The policy front door (authn, authz, API allowlist) + its Helm copy
/opa/policies/                              @thomasdarimont
/deploy/helm/pgauthz/files/opa/policies/    @thomasdarimont

# pgauthzd front door: JWT validation, issuer bindings, role switching,
# the native callback listener, and freshness-token signing/verification
/pgauthzd/internal/api/       @thomasdarimont
/pgauthzd/internal/config/    @thomasdarimont
/pgauthzd/internal/authz/     @thomasdarimont
/pgauthzd/internal/app/       @thomasdarimont

# CI and release machinery
/.github/           @thomasdarimont
/scripts/           @thomasdarimont
/deploy/            @thomasdarimont
