### PostgREST Writer — Security boundary verification.
### Requires: docker compose up (with postgrest-writer + writer-gateway)
### Select the "dev" environment to use the variables below.
###
### Tokens are HS256 JWTs signed with the default dev secret.
### writer_token has role=authz_writer, admin_token has role=authz_admin.
###
### Each request documents the expected HTTP status code and why.
###
### Requests go through the Nginx writer-gateway which only forwards
### POST /rpc/* to PostgREST. Everything else gets a generic 404.
###
### For RPC calls that reach PostgREST:
###   - 401 = no JWT (anonymous role lacks privilege)
###   - 403 = valid JWT but claimed role lacks privilege

### =====================================================================
### 1. NGINX GATEWAY — blocks non-RPC routes
### =====================================================================

### GET / blocked by Nginx (not forwarded)
GET {{writer_url}}/
### Expected: HTTP 404, body: {"message":"Not Found"}

###

### GET table endpoint blocked by Nginx (not /rpc/ prefix)
GET {{writer_url}}/namespace_access
### Expected: HTTP 404, body: {"message":"Not Found"}

###

### GET table with writer JWT — still blocked by Nginx
GET {{writer_url}}/namespace_access
Authorization: Bearer {{writer_token}}
### Expected: HTTP 404 (Nginx rejects before PostgREST sees it)

###

### GET table with admin JWT — still blocked by Nginx
GET {{writer_url}}/namespace_access
Authorization: Bearer {{admin_token}}
### Expected: HTTP 404

###

### POST to table endpoint blocked by Nginx (not /rpc/ prefix)
POST {{writer_url}}/namespace_access
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "store_id": 1,
  "namespace": "evil",
  "db_role": "evil_role",
  "can_read": true,
  "can_write": true
}
### Expected: HTTP 404 (Nginx only forwards /rpc/)

###

### Non-existent RPC function — Nginx forwards, PostgREST 404 is
### intercepted and replaced with generic response (no schema leak)
POST {{writer_url}}/rpc/does_not_exist
Content-Type: application/json

{}
### Expected: HTTP 404, body: {"message":"Not Found"} (no function hints)

###

### =====================================================================
### 2. UNAUTHENTICATED ACCESS — no JWT
### =====================================================================

### Read functions work without JWT (api_anon inherits authz_reader)
POST {{writer_url}}/rpc/check_access
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "can_read",
  "p_object_type": "document",
  "p_object_id": "doc_payroll_001"
}
### Expected: HTTP 200, body: true

###

### write_tuple blocked without JWT
POST {{writer_url}}/rpc/write_tuple
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "eve",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_payroll_001",
  "p_performed_by": "attacker"
}
### Expected: HTTP 401 (api_anon has no EXECUTE on write_tuple)

###

### create_store blocked without JWT
POST {{writer_url}}/rpc/create_store
Content-Type: application/json

{
  "p_name": "evil_store"
}
### Expected: HTTP 401

###

### audit_list_user blocked without JWT
POST {{writer_url}}/rpc/audit_list_user
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice"
}
### Expected: HTTP 401

###

### =====================================================================
### 3. WRITER JWT — can write tuples but NOT admin/audit functions
### =====================================================================

### write_tuple allowed with writer JWT
POST {{writer_url}}/rpc/write_tuple
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "__sectest__",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_seccheck",
  "p_performed_by": "security-check"
}
### Expected: HTTP 200

###

### delete_tuple allowed with writer JWT
POST {{writer_url}}/rpc/delete_tuple
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "__sectest__",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_seccheck",
  "p_performed_by": "security-check"
}
### Expected: HTTP 200

###

### check_access allowed with writer JWT (inherits reader)
POST {{writer_url}}/rpc/check_access
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "can_read",
  "p_object_type": "document",
  "p_object_id": "doc_payroll_001"
}
### Expected: HTTP 200, body: true

###

### create_store blocked with writer JWT (admin only)
POST {{writer_url}}/rpc/create_store
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_name": "writer_store"
}
### Expected: HTTP 403 (writer cannot create stores)

###

### delete_store blocked with writer JWT (admin only)
POST {{writer_url}}/rpc/delete_store
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo"
}
### Expected: HTTP 403 (writer cannot delete stores)

###

### audit_list_user blocked with writer JWT (auditor/admin only)
POST {{writer_url}}/rpc/audit_list_user
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice"
}
### Expected: HTTP 403 (writer cannot query audit trail)

###

### import_openfga_model blocked with writer JWT (admin only)
POST {{writer_url}}/rpc/import_openfga_model
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_model": {}
}
### Expected: HTTP 403 (writer cannot import models)

###

### grant_namespace_access blocked with writer JWT (admin only)
POST {{writer_url}}/rpc/grant_namespace_access
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_namespace": "document",
  "p_db_role": "evil_role",
  "p_can_read": true,
  "p_can_write": true
}
### Expected: HTTP 403 (writer cannot modify namespace access)

###

### =====================================================================
### 4. ADMIN JWT — full access including admin and audit functions
### =====================================================================

### write_tuple allowed with admin JWT
POST {{writer_url}}/rpc/write_tuple
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "__sectest__",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_seccheck",
  "p_performed_by": "security-check"
}
### Expected: HTTP 200

###

### audit_list_user allowed with admin JWT (admin inherits auditor)
POST {{writer_url}}/rpc/audit_list_user
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice"
}
### Expected: HTTP 200, body: array of audit entries

###

### find_redundant_tuples allowed with admin JWT
POST {{writer_url}}/rpc/find_redundant_tuples
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo"
}
### Expected: HTTP 200, body: array (may be empty)

###

### model_register_type allowed with admin JWT
POST {{writer_url}}/rpc/model_register_type
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_type_name": "seccheck_type",
  "p_hash_modulus": 0
}
### Expected: HTTP 200, body: smallint (new type ID)

###

### Cleanup: delete test tuple
POST {{writer_url}}/rpc/delete_tuple
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "__sectest__",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_seccheck",
  "p_performed_by": "security-check"
}
### Expected: HTTP 200
