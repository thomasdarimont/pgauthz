### PostgREST Write API examples against the demo model.
### Writes go through the Nginx gateway (port 3001) with JWT authentication.
### After each write, a read check via PostgREST (port 3000) verifies the result.
### Requires: docker compose up (bootstrap.sh)
### Select the "dev" environment to use the variables below.

### =====================================================================
### WRITE A SINGLE TUPLE
### =====================================================================

### Grant alice viewer on a new document
POST {{writer_url}}/rpc/write_tuple
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_test_001",
  "p_performed_by": "http-client"
}
### Expected: null (void function, HTTP 200)

###

### Verify: alice can now read doc_test_001
POST {{postgrest_url}}/rpc/check_access
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "can_read",
  "p_object_type": "document",
  "p_object_id": "doc_test_001"
}
### Expected: true

###

### =====================================================================
### BATCH WRITE (JSONB)
### =====================================================================

### Grant multiple users access in a single call
POST {{writer_url}}/rpc/write_tuples_jsonb
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_tuples": [
    { "user_type": "internal_user", "user_id": "alice", "relation": "editor", "object_type": "document", "object_id": "doc_test_001" },
    { "user_type": "internal_user", "user_id": "bob",   "relation": "viewer", "object_type": "document", "object_id": "doc_test_001" }
  ],
  "p_performed_by": "http-client"
}
### Expected: 2 (number of tuples inserted, duplicates skipped)

###

### Verify: bob can now read doc_test_001
POST {{postgrest_url}}/rpc/check_access
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "bob",
  "p_relation": "can_read",
  "p_object_type": "document",
  "p_object_id": "doc_test_001"
}
### Expected: true

###

### Verify: alice can edit doc_test_001 (editor was granted above)
POST {{postgrest_url}}/rpc/check_access
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "can_edit",
  "p_object_type": "document",
  "p_object_id": "doc_test_001"
}
### Expected: true

###

### =====================================================================
### DELETE A SINGLE TUPLE
### =====================================================================

### Revoke alice's viewer on doc_test_001
POST {{writer_url}}/rpc/delete_tuple
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_test_001",
  "p_performed_by": "http-client"
}
### Expected: null (void function, HTTP 200)

###

### =====================================================================
### BATCH DELETE (JSONB)
### =====================================================================

### Remove multiple tuples in a single call
POST {{writer_url}}/rpc/delete_tuples_jsonb
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_tuples": [
    { "user_type": "internal_user", "user_id": "alice", "relation": "editor", "object_type": "document", "object_id": "doc_test_001" },
    { "user_type": "internal_user", "user_id": "bob",   "relation": "viewer", "object_type": "document", "object_id": "doc_test_001" }
  ],
  "p_performed_by": "http-client"
}
### Expected: 2 (number of tuples deleted)

###

### Verify: bob can no longer read doc_test_001
POST {{postgrest_url}}/rpc/check_access
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "bob",
  "p_relation": "can_read",
  "p_object_type": "document",
  "p_object_id": "doc_test_001"
}
### Expected: false

###

### =====================================================================
### DELETE ALL TUPLES FOR A USER (offboarding)
### =====================================================================

### First create a test tuple, then delete all tuples for the user
POST {{writer_url}}/rpc/write_tuple
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "__offboard_test__",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_test_001",
  "p_performed_by": "http-client"
}
### Expected: null (HTTP 200)

###

### Revoke all access for the test user
POST {{writer_url}}/rpc/delete_user_tuples
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "__offboard_test__",
  "p_performed_by": "offboarding"
}
### Expected: 1 (number of tuples deleted)

###

### =====================================================================
### WRITE WITH AUDIT TRACKING
### =====================================================================

### Write a tuple with performed_by for audit trail
POST {{writer_url}}/rpc/write_tuple
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_test_audit",
  "p_performed_by": "document-service"
}
### Expected: null (HTTP 200)

###

### Verify: check the audit trail (requires admin JWT)
POST {{writer_url}}/rpc/audit_list_object
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_object_type": "document",
  "p_object_id": "doc_test_audit"
}
### Expected: array with audit entry showing performed_by="document-service"

###

### Cleanup: remove test tuples
POST {{writer_url}}/rpc/delete_tuple
Authorization: Bearer {{writer_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_test_audit",
  "p_performed_by": "cleanup"
}
### Expected: null (HTTP 200)

###

### =====================================================================
### SECURITY: UNAUTHENTICATED WRITES MUST FAIL
### =====================================================================

### Write without token — should fail with 401
POST {{writer_url}}/rpc/write_tuple
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "eve",
  "p_relation": "viewer",
  "p_object_type": "document",
  "p_object_id": "doc_payroll_001",
  "p_performed_by": "attacker"
}
### Expected: HTTP 401 (insufficient privileges — api_anon has no EXECUTE on write_tuple)

###

### =====================================================================
### ADMIN OPERATIONS (authz_admin)
### =====================================================================

### Register a new object type (admin only)
POST {{writer_url}}/rpc/model_register_type
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_type_name": "invoice",
  "p_hash_modulus": 0
}
### Expected: smallint (the new type's ID)

###

### Register a new relation (admin only)
POST {{writer_url}}/rpc/model_register_relation
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_relation_name": "can_approve",
  "p_description": "Approval permission"
}
### Expected: smallint (the new relation's ID)

###

### Add a model rule — direct rule (admin only)
POST {{writer_url}}/rpc/model_add_rule
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_object_type": "document",
  "p_relation": "viewer",
  "p_rule_type": "direct"
}
### Expected: smallint (the rule's ID)

###

### Add a model rule — computed rule (admin only)
POST {{writer_url}}/rpc/model_add_rule
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_object_type": "document",
  "p_relation": "can_read",
  "p_rule_type": "computed",
  "p_computed_relation": "viewer"
}
### Expected: smallint (the rule's ID)

###

### Remove a single model rule by ID (admin only)
POST {{writer_url}}/rpc/model_remove_rule
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_rule_id": 1
}
### Expected: true/false (whether a rule was deleted)

###

### Remove all model rules for a relation (admin only)
POST {{writer_url}}/rpc/model_remove_rules
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_object_type": "document",
  "p_relation": "can_read"
}
### Expected: integer (number of rules deleted)

###

### Find redundant tuples (admin maintenance)
POST {{writer_url}}/rpc/find_redundant_tuples
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo"
}
### Expected: array of redundant tuples (may be empty)

###

### =====================================================================
### AUDIT QUERIES (authz_auditor or authz_admin)
### =====================================================================

### Audit trail for a user
POST {{writer_url}}/rpc/audit_list_user
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "p_store": "demo",
  "p_user_type": "internal_user",
  "p_user_id": "alice"
}
### Expected: array of audit entries showing permission changes
